# ════════════════════════════════════════════════════════════════════════════
#  AI Multi-Agent Telegram Bot — فایل تنظیمات
#
#  راهنما: این فایل را به نام .env کپی کنید و مقادیر را پر کنید.
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════════════════

# ── AI Provider (پیشفرض — از پنل ادمین هم قابل تنظیم) ───────────────────────
# پیشنهاد: Bynara Router — ۷ میلیون توکن رایگان با ثبت‌نام:
#   https://router.bynara.id/register?ref=NMAP6F9D
BYNARA_BASE_URL=https://router.bynara.id/v1
BYNARA_API_KEY=your_api_key_here

# مدل پیشفرض برای تمام Agentها
BYNARA_MODEL=gpt-4o-mini

# مدل اختصاصی برای Agent ناظر
BYNARA_SUPERVISOR_MODEL=gpt-4o-mini

# ── Telegram ─────────────────────────────────────────────────────────────────
# توکن ربات — از پنل ادمین هم میتوانید اضافه کنید
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# پاسخ به همه پیامهای گروه؟
BOT_RESPOND_TO_ALL=false

# حداقل فاصله زمانی بین پردازش پیامهای یک چت (ثانیه)
RATE_LIMIT_SECONDS=3

# ── LangSmith (مانیتورینگ پیشرفته) ──────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ai-telegram-agents
LANGSMITH_TRACING=true

# ── تنظیمات Agent ────────────────────────────────────────────────────────────
AGENT_TEMPERATURE=0.7
SUPERVISOR_TEMPERATURE=0.2
MAX_HISTORY=6

# ── پنل مدیریت وب ────────────────────────────────────────────────────────────
PANEL_HOST=0.0.0.0
PANEL_PORT=8080

# ── متفرقه ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
BOT_NAME=AI Agent Team